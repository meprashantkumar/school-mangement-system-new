# Dependencies
node_modules/
**/node_modules/

# Builds
dist/
build/
**/dist/
**/build/
*.tsbuildinfo

# Environment / secrets — never commit real values (templates like .env.example are OK)
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# SSH / private keys / certificates — never commit
*.key
*.pem
*.ppk
*.p12
*.pfx
*.crt
*.cer
id_rsa*
id_ed25519*
id_dsa*
ssh-key-*

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/

# Test / coverage
coverage/
