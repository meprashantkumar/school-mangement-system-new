PORT=5000
NODE_ENV=development

# MongoDB connection string (local mongod or MongoDB Atlas)
MONGO_URI=mongodb://localhost:27017/sfms

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRE=7d

# Super admin auto-created on first server start
SUPERADMIN_NAME=Super Admin
SUPERADMIN_EMAIL=superadmin@school.com
SUPERADMIN_PASSWORD=super123

# Frontend URL (CORS + email links)
CLIENT_URL=http://localhost:5173

# Razorpay TEST keys (https://dashboard.razorpay.com -> Test Mode)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Convenience fee for online payments from home, as a PERCENTAGE of the amount
# paid (counter/UPI-QR payments have no charge). Razorpay keeps 2% + 18% GST =
# 2.36% of the total, so 2.5% (rounded up to the rupee) covers the gateway cut on
# every payment and the school never runs at a loss.
ONLINE_PLATFORM_FEE_PCT=2.5
# School UPI ID + name for the counter QR (parents scan and pay, no gateway charge)
SCHOOL_UPI_VPA=school@upi
SCHOOL_UPI_NAME=School Fee Office

# Where the "Backup now" button writes its temporary dump before sending it to
# the browser (defaults to the OS temp dir if left blank). Requires the
# mongodb-database-tools package (mongodump) to be installed on the server.
BACKUP_DIR=

# Email (nodemailer) - optional, for receipt/reminder emails
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="School Fee System <no-reply@sfms.local>"
