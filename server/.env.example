PORT=5000
NODE_ENV=development

# MongoDB connection string (local mongod or MongoDB Atlas)
MONGO_URI=mongodb://localhost:27017/sfms

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRE=7d

# Super admin auto-created on first server start
SUPERADMIN_NAME=Super Admin
SUPERADMIN_EMAIL=superadmin@school.com
SUPERADMIN_PASSWORD=super123

# Frontend URL (CORS + email links)
CLIENT_URL=http://localhost:5173

# Razorpay TEST keys (https://dashboard.razorpay.com -> Test Mode)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Platform fee (rupees) added to online payments from home; counter QR has no charge
ONLINE_PLATFORM_FEE=20
# School UPI ID + name for the counter QR (parents scan and pay, no gateway charge)
SCHOOL_UPI_VPA=school@upi
SCHOOL_UPI_NAME=School Fee Office

# Email (nodemailer) - optional, for receipt/reminder emails
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="School Fee System <no-reply@sfms.local>"
