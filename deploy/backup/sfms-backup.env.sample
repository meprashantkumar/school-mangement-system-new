# Sample config for sfms-backup.sh.
#
# Copy this to /etc/sfms-backup.env on the server, fill in real values, then
# lock it down so only root can read it (it contains the DB connection string):
#
#   sudo cp sfms-backup.env.sample /etc/sfms-backup.env
#   sudo nano /etc/sfms-backup.env
#   sudo chmod 600 /etc/sfms-backup.env
#
# DO NOT commit the real /etc/sfms-backup.env to git.

# Connection string to the database being backed up.
# For self-hosted Mongo with auth, include the user/password + authSource:
#   mongodb://sfms_backup:PASSWORD@127.0.0.1:27017/sfms?authSource=admin
MONGO_URI="mongodb://127.0.0.1:27017/sfms"

# Local folder for the temporary dump (a few recent copies are kept here too).
STAGING_DIR="/var/backups/sfms"

# Off-box destination — an rclone remote you configured with `rclone config`.
# Format is  <remote-name>:<bucket-or-path>. REQUIRED for a real backup.
RCLONE_REMOTE="ocibackup:sfms-backups"

# Optional second destination on a DIFFERENT provider/account for extra safety.
# Leave blank to skip. e.g. Backblaze B2 or Google Drive.
RCLONE_REMOTE_2=""

# Retention (grandfather-father-son). Defaults are sensible; tune if you like.
KEEP_DAILY_DAYS="14"
KEEP_WEEKLY_DAYS="70"
KEEP_MONTHLY_DAYS="400"

# How many recent dumps to keep on the server itself (fast local restore).
KEEP_LOCAL="3"

# Where the script writes its log.
LOG_FILE="/var/log/sfms-backup.log"
